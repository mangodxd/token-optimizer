{
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'COMPACTION GUIDANCE: Preserve code changes, key decisions, and file paths. Discard intermediate attempts, explanations, and verbose tool output.'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 '$MEASURE_PY' compact-capture --trigger auto --quiet"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 '$MEASURE_PY' compact-restore"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 '$MEASURE_PY' compact-restore --new-session-only"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 '$MEASURE_PY' compact-capture --trigger stop --quiet"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 '$MEASURE_PY' collect --quiet && python3 '$MEASURE_PY' dashboard --quiet"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 '$MEASURE_PY' compact-capture --trigger end --quiet"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 '$MEASURE_PY' quality-cache --warn --quiet"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'File modified. Skip formatting explanations. The formatter handles it.'"
          }
        ]
      }
    ]
  }
}
